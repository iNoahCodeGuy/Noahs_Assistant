# Portfolia backend configuration.
# Copy to .env and fill in the four required values — the rest are optional.

# ── Required ────────────────────────────────────────────────────────────────

# OpenAI — embeddings only (text-embedding-3-small, 1536 dims)
OPENAI_API_KEY=sk-your_openai_api_key

# Anthropic — generation (Claude Sonnet 4.5) and intent classification (Claude Haiku)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Supabase — pgvector knowledge base, conversation logs, leads, confessions
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Optional: notifications (crush confessions & contact-form alerts) ──────

# Twilio SMS — https://twilio.com/try-twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890
# Confession SMS is always sent TO this number; visitor contact info goes in
# the message body, never in the TO field.
NOAH_PHONE_NUMBER=+1234567890
# General contact alerts (non-crush notifications)
ADMIN_PHONE_NUMBER=+1234567890

# Resend email — https://resend.com
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev
ADMIN_EMAIL=you@example.com

# ── Optional: observability (LangSmith tracing) ────────────────────────────

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_your_langsmith_api_key
LANGCHAIN_PROJECT=portfolia

# ── Optional: error monitoring (Sentry) ────────────────────────────────────

# When set, unhandled backend errors are reported to Sentry (errors only,
# no performance tracing — LangSmith owns tracing).
# SENTRY_DSN=https://examplekey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production

# ── Optional: overrides (defaults are set in assistant/config) ─────────────

# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# FRONTEND_URL=https://noahdelacalzada.com   # added to the CORS allow-list
# LINKEDIN_URL=https://www.linkedin.com/in/your-profile/
